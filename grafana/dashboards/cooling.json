          "queryType": "time series",
          "rawQueryText": "SELECT unixepoch(timestamp) AS time,\n       sensor,\n       celsius AS value\nFROM readings\nWHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000\n  AND sensor IN ('sensor_0', 'sensor_1')\n  AND celsius BETWEEN -20 AND 100\nORDER BY 1",
