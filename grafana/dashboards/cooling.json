{
  "uid": "cool-eva-main",
  "title": "Cool Eva — Battery Cooling",
  "tags": ["cool-eva", "motorcycle", "cooling"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "",
  "time": {
    "from": "2026-04-12T00:00:00.000Z",
    "to": "2026-05-25T00:00:00.000Z"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Max inlet",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 20 },
              { "color": "yellow", "value": 35 },
              { "color": "orange", "value": 45 },
              { "color": "red", "value": 55 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT MAX(celsius) AS value FROM readings WHERE sensor = 'sensor_0' AND unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000",
          "timeColumns": [],
          "queryType": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max outlet",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 20 },
              { "color": "yellow", "value": 35 },
              { "color": "orange", "value": 45 },
              { "color": "red", "value": 55 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT MAX(celsius) AS value FROM readings WHERE sensor = 'sensor_1' AND unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000",
          "timeColumns": [],
          "queryType": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Max ΔT (outlet − inlet)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT MAX(delta) AS value FROM (\n  SELECT (unixepoch(timestamp) / 5) * 5 AS t,\n         AVG(CASE WHEN sensor='sensor_1' THEN celsius END)\n           - AVG(CASE WHEN sensor='sensor_0' THEN celsius END) AS delta\n  FROM readings\n  WHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000\n  GROUP BY t\n)\nWHERE delta IS NOT NULL",
          "timeColumns": [],
          "queryType": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Readings in range",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT COUNT(*) AS value FROM readings WHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000",
          "timeColumns": [],
          "queryType": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Coolant temperatures — inlet vs outlet",
      "description": "30-second buckets. Inlet (sensor_0) was installed first; outlet (sensor_1) data starts 2026-05-10.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1.5,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto",
            "axisLabel": "°C"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": []
          },
          {
            "matcher": { "id": "byName", "options": "sensor_0" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "displayName", "value": "inlet" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sensor_1" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "displayName", "value": "outlet" }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT (unixepoch(timestamp) / 30) * 30 AS time,\n       sensor,\n       AVG(celsius) AS value\nFROM readings\nWHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000\n  AND sensor IN ('sensor_0', 'sensor_1')\n  AND celsius BETWEEN -20 AND 100\nGROUP BY 1, 2\nORDER BY 1",
          "timeColumns": ["time"],
          "queryType": "time series"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "ΔT across battery (outlet − inlet)",
      "description": "Heat pulled out of the battery pack. Positive ΔT means the pack is dumping heat into the coolant.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1.5,
            "fillOpacity": 15,
            "showPoints": "never",
            "gradientMode": "opacity",
            "axisLabel": "ΔT (°C)"
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "cool-eva-sqlite" },
          "rawQueryText": "SELECT (unixepoch(timestamp) / 30) * 30 AS time,\n       'ΔT' AS series,\n       AVG(CASE WHEN sensor='sensor_1' AND celsius BETWEEN -20 AND 100 THEN celsius END)\n         - AVG(CASE WHEN sensor='sensor_0' AND celsius BETWEEN -20 AND 100 THEN celsius END) AS value\nFROM readings\nWHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000\nGROUP BY 1\nHAVING value IS NOT NULL\nORDER BY 1",
          "timeColumns": ["time"],
          "queryType": "time series"
        }
      ]
    }
  ]
}
