          "queryType": "time series",
          "rawQueryText": "SELECT unixepoch(timestamp) AS time,\n       '\u0394T' AS series,\n       AVG(CASE WHEN sensor='sensor_1' AND celsius BETWEEN -20 AND 100 THEN celsius END)\n         - AVG(CASE WHEN sensor='sensor_0' AND celsius BETWEEN -20 AND 100 THEN celsius END) AS value\nFROM readings\nWHERE unixepoch(timestamp) BETWEEN $__from / 1000 AND $__to / 1000\nGROUP BY time\nHAVING value IS NOT NULL\nORDER BY 1",
          "refId": "A",
